# ── REQUIRED IN PRODUCTION (Render) ──────────────────────────────────
# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# JWT signing key (if JWT auth is used). Generate same way as SECRET_KEY.
JWT_SECRET=

# Initial admin password. If not set, a random one is generated and printed to console on first boot.
ADMIN_INIT_PASSWORD=

# ── API Keys ─────────────────────────────────────────────────────────
# OpenAI API Key (required for AI features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# NewsData.io API Key (for direct search feature)
# Get your API key from: https://newsdata.io/
NEWSDATA_API_KEY=pub_df0fbdacb76e448e9dadfshsdfghsdhtsdh

# External API key for /api/external/headlines (sent via X-API-Key header)
EXTERNAL_API_KEY=

# ── OPTIONAL ─────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (e.g. https://your-app.onrender.com)
# Leave empty for same-origin deployment (Flask serves frontend from /static)
CORS_ORIGINS=

# Set to 'true' to mark session cookies as Secure (auto-enabled when RENDER env var is set)
SESSION_COOKIE_SECURE=false

# Database URL (auto-set by Render for PostgreSQL; defaults to SQLite locally)
# DATABASE_URL=sqlite:///ain_monitor.db
